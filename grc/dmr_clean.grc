  parameters:
    comment: 'Each burst = [carrier preamble][data][silence]. Preamble (value 4 =
      0 Hz deviation) warms up the radio before data. Silence shortened by preamble_symbols
      so total frame length is unchanged: preamble_symbols + 132 + (156*num_silence_slots
      - preamble_symbols) = 132 + 156*N'
    value: sum([[4]*preamble_symbols + [int(bin(h)[2:].zfill(264)[i:i+2], 2) for i
      in range(0, 264, 2)] + [4]*(156 * num_silence_slots - preamble_symbols) for
      h in hex_words], [])
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [544, 16.0]
    rotation: 0
    state: enabled
