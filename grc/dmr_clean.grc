- name: epy_block_0
  id: epy_block
  parameters:
    _source_code: "import numpy as np\nfrom gnuradio import gr\nimport pmt\n\nclass\
      \ blk(gr.sync_block):\n    def __init__(self, num_silence_slots=1, preamble_symbols=5,\
      \ postamble_symbols=3):\n        gr.sync_block.__init__(self,\n            name='Add\
      \ Zero Tag',\n            in_sig=[np.float32],\n            out_sig=[np.float32]\n\
      \        )\n        self.zero_tag = pmt.string_to_symbol(\"zero_samples\")\n\
      \        self.data_symbols = 132\n        self.idle_symbols_per_slot = 156\n\
      \        self.num_silence_slots = int(num_silence_slots)\n        self.preamble_symbols\
      \ = int(preamble_symbols)\n        self.postamble_symbols = int(postamble_symbols)\n\
      \        self.idle_symbols = self.idle_symbols_per_slot * self.num_silence_slots\n\
      \        self.burst_symbols = self.data_symbols + self.idle_symbols\n      \
      \  self.samples_per_symbol = 5\n        self.tag_pos = self.preamble_symbols\
      \ + self.data_symbols + self.postamble_symbols\n        self.zero_samples =\
      \ (self.idle_symbols - self.preamble_symbols - self.postamble_symbols) * self.samples_per_symbol\n\
      \n    def work(self, input_items, output_items):\n        in0 = input_items[0]\n\
      \        out = output_items[0]\n        out[:] = in0\n        n = len(out)\n\
      \        start = self.nitems_written(0)\n        for i in range(n):\n      \
      \      pos = (start + i) % self.burst_symbols\n            if pos == self.tag_pos:\n\
      \                val = pmt.from_uint64(self.zero_samples)\n                self.add_item_tag(0,\
      \ start + i, self.zero_tag, val)\n        return len(out)"
    affinity: ''
    alias: ''
    comment: ''
    maxoutbuf: '0'
    minoutbuf: '0'
    num_silence_slots: num_silence_slots
    postamble_symbols: postamble_symbols
    preamble_symbols: preamble_symbols
  states:
    _io_cache: ('Add Zero Tag', 'blk', [('num_silence_slots', '1'), ('preamble_symbols',
      '5'), ('postamble_symbols', '3')], [('0', 'float', 1)], [('0', 'float', 1)],
      '', ['num_silence_slots', 'postamble_symbols', 'preamble_symbols'])
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [488, 224.0]
    rotation: 0
    state: enabled
- name: epy_block_1_0
  id: epy_block
  parameters:
    _source_code: "import numpy as np\nfrom gnuradio import gr\nimport pmt\n\nclass\
      \ blk(gr.sync_block):\n    def __init__(self):\n        gr.sync_block.__init__(self,\n\
      \            name='Zero Idle Bursts',\n            in_sig=[np.complex64],\n\
      \            out_sig=[np.complex64]\n        )\n        self.set_history(128)\
      \  # Safe buffer for delayed tag detection\n        self.zero_tag = pmt.string_to_symbol(\"\
      zero_samples\")\n        self.sample_counter = 0\n        #self.delay = 62 \
      \ # (125-1)//2 for RRC taps\n        self.delay = 62  # (125-1)//2 for RRC taps\n\
      \n\n    def work(self, input_items, output_items):\n        in0 = input_items[0]\n\
      \        out = output_items[0]\n        n = len(out)\n        tags = self.get_tags_in_window(0,\
      \ 0, n, self.zero_tag)\n        if tags:\n            tags = sorted(tags, key=lambda\
      \ t: t.offset)\n        abs_n = self.nitems_written(0)\n        for i in range(n):\n\
      \            for tag in tags:\n                if tag.offset == abs_n + i -\
      \ self.delay:  # Negative delay postpones zeroing\n                    self.sample_counter\
      \ = pmt.to_uint64(tag.value)\n                    break\n            if self.sample_counter\
      \ > 0:\n                out[i] = 0 + 0j\n                self.sample_counter\
      \ -= 1\n            else:\n                out[i] = in0[i]\n        return len(out)"
    affinity: ''
    alias: ''
    comment: ''
    maxoutbuf: '0'
    minoutbuf: '0'
  states:
    _io_cache: ('Zero Idle Bursts', 'blk', [], [('0', 'complex', 1)], [('0', 'complex',
      1)], '', [])
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [1304, 336.0]
    rotation: 0
    state: enabled
