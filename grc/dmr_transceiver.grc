- name: snippet_0
  id: snippet
  parameters:
    alias: ''
    code: "import threading\nimport time\nfrom subprocess import Popen\n\n\ndef callback_dsd():\n\
      \  Popen(\"nc -lu 52052 | dsd-fme -i - -Q ../../../../../../../tmp/out\", shell=True)\n\
      \ndef callback_nc():\n  Popen(\"alacritty -e \\\"bash -c 'nc -lu 52020'\\\"\"\
      , shell=True)\n\n\ndsd_thread = threading.Thread(target=callback_dsd, daemon=True)\n\
      dsd_thread.start()\n\n#nc_thread = threading.Thread(target=callback_nc, daemon=True)\n\
      #nc_thread.start()"
