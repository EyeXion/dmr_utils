- name: epy_block_0
  id: epy_block
  parameters:
    _source_code: "import numpy as np\nfrom gnuradio import gr\nimport pmt\nimport\
      \ socket\nimport threading\nfrom collections import deque\n\nclass blk(gr.sync_block):\n\
      \    def __init__(self, ip='127.0.0.1', port=52005):\n        gr.sync_block.__init__(\n\
      \            self,\n            name='Alors \xE7a burst ?',\n            in_sig=None,\n\
      \            out_sig=[np.float32]\n        )\n        self.ip = ip\n       \
      \ self.port = port\n        self.map = {0: 0.5, 1: 1.5, 2: -0.5, 3: -1.5}\n\
      \        \n        self.burst_queue = deque() \n        self.current_frame =\
      \ []\n        \n        # State counters\n        self.mandatory_silence_left\
      \ = 0\n        self.flushing_done_count = 0 # Total zeros sent since the end\
      \ of the last data frame\n        \n        self.stop_thread = threading.Event()\
      \ \n        self.thread = threading.Thread(target=self.socket_listener, daemon=True)\n\
      \        self.thread.start()\n\n    def socket_listener(self):\n        sock\
      \ = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)\n        sock.setsockopt(socket.SOL_SOCKET,\
      \ socket.SO_REUSEADDR, 1)\n        sock.bind((self.ip, self.port))\n       \
      \ sock.settimeout(0.5)\n        \n        while not self.stop_thread.is_set():\n\
      \            try:\n                data, addr = sock.recvfrom(1024)\n      \
      \          if len(data) >= 35:\n                    bytes_array = np.frombuffer(data[:33],\
      \ dtype=np.uint8)\n                    dibits = []\n                    for\
      \ b in bytes_array:\n                        dibits.append(self.map[(b >> 6)\
      \ & 0x03])\n                        dibits.append(self.map[(b >> 4) & 0x03])\n\
      \                        dibits.append(self.map[(b >> 2) & 0x03])\n        \
      \                dibits.append(self.map[b & 0x03])\n                    \n \
      \                   frame = [0.0, 0.0] + dibits + [0.0, 0.0] # 136 symbols total\n\
      \n                    silence_duration = int.from_bytes(data[33:35], byteorder='big')\n\
      \                    \n                    self.burst_queue.append((frame, silence_duration))\n\
      \            except socket.timeout:\n                continue\n            except\
      \ Exception:\n                break\n        sock.close()\n\n    def work(self,\
      \ input_items, output_items):\n        out = output_items[0]\n        n_out\
      \ = len(out)\n        produced = 0\n\n        while produced < n_out:\n\n  \
      \          if self.current_frame:\n                n_to_send = min(n_out - produced,\
      \ len(self.current_frame))\n                out[produced:produced + n_to_send]\
      \ = self.current_frame[:n_to_send]\n                \n                self.current_frame\
      \ = self.current_frame[n_to_send:]\n                produced += n_to_send\n\
      \                \n                if not self.current_frame:\n            \
      \        self.flushing_done_count = 0\n                continue\n\n        \
      \    if self.mandatory_silence_left > 0:\n                n_silence = min(n_out\
      \ - produced, self.mandatory_silence_left)\n                out[produced:produced\
      \ + n_silence] = [0.0] * n_silence\n                \n                self.mandatory_silence_left\
      \ -= n_silence\n                self.flushing_done_count += n_silence\n    \
      \            produced += n_silence\n                continue\n\n           \
      \ if self.burst_queue:\n                frame_data, silence_val = self.burst_queue.popleft()\n\
      \                self.current_frame = frame_data\n                self.mandatory_silence_left\
      \ = silence_val\n                \n                abs_index = self.nitems_written(0)\
      \ + produced\n                self.add_item_tag(0, abs_index, pmt.intern(\"\
      tx_sob\"), pmt.from_bool(True))\n                self.add_item_tag(0, abs_index\
      \ + 136, pmt.intern(\"tx_eob\"), pmt.from_bool(True))\n                continue\n\
      \n            if self.flushing_done_count < 30:\n                n_flush = min(n_out\
      \ - produced, 30 - self.flushing_done_count)\n                out[produced:produced\
      \ + n_flush] = [0.0] * n_flush\n                \n                self.flushing_done_count\
      \ += n_flush\n                produced += n_flush\n                continue\n\
      \n            if produced > 0:\n                return produced\n          \
      \  else:\n                return 0\n\n        return produced\n\n    def stop(self):\n\
      \        self.stop_thread.set()\n        self.thread.join(timeout=0.2)\n   \
      \     return True"
    affinity: ''
    alias: ''
    comment: ''
    ip: '''127.0.0.1'''
    maxoutbuf: '0'
    minoutbuf: '0'
    port: '52010'
  states:
    _io_cache: "('Alors \xE7a burst ?', 'blk', [('ip', \"'127.0.0.1'\"), ('port',\
      \ '52005')], [], [('0', 'float', 1)], '', ['ip', 'port'])"
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [216, 216.0]
    rotation: 0
    state: disabled
- name: epy_block_0_0
  id: epy_block
  parameters:
    _source_code: "import numpy as np\nfrom gnuradio import gr\nimport pmt\nimport\
      \ socket\nimport threading\nfrom collections import deque\n\nclass blk(gr.sync_block):\n\
      \    def __init__(self, ip='127.0.0.1', port=52005):\n        gr.sync_block.__init__(\n\
      \            self,\n            name='Burstidi burstidou burstiditipou',\n \
      \           in_sig=None,\n            out_sig=[np.float32]\n        )\n    \
      \    self.ip = ip\n        self.port = port\n        self.map = {0: 0.5, 1:\
      \ 1.5, 2: -0.5, 3: -1.5}\n        \n        # les bursts \xE0 la queleuleu\n\
      \        self.burst_queue = deque() \n        self.current_frame = []\n    \
      \    \n        # thread parceque sinon delay avec socket, enfin hypth\xE8se\
      \ (je vais me tirer une balle)\n        self.stop_thread = threading.Event()\
      \ \n        self.thread = threading.Thread(target=self.socket_listener, daemon=True)\n\
      \        self.thread.start()\n\n        self.flush_needed = 0\n\n    def socket_listener(self):\n\
      \        sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)\n        sock.setsockopt(socket.SOL_SOCKET,\
      \ socket.SO_REUSEADDR, 1)\n        sock.bind((self.ip, self.port))\n       \
      \ sock.settimeout(0.5)\n        \n        while not self.stop_thread.is_set():\n\
      \            try:\n                data, addr = sock.recvfrom(1024)\n      \
      \          if len(data) == 33:\n                    bytes_array = np.frombuffer(data,\
      \ dtype=np.uint8)\n                    dibits = []\n                    for\
      \ b in bytes_array:\n                        dibits.append(self.map[(b >> 6)\
      \ & 0x03])\n                        dibits.append(self.map[(b >> 4) & 0x03])\n\
      \                        dibits.append(self.map[(b >> 2) & 0x03])\n        \
      \                dibits.append(self.map[b & 0x03])\n                    \n \
      \                   # Ici, frame avec preamble + postable pour ne pas avoir\
      \ de coupure de bits\n                    # les tags sont sur le 1er et dernier\
      \ de ce tableau !\n                    frame = [0.0, 0.0] + dibits + [0.0, 0.0]\n\
      \                    \n                    # des 0 pour flush les filtres, sinon\
      \ on a un pb quelque part ils ont besoin\n                    # d'un minimum\
      \ de data pour se flush. Et puis faut que notre paquet sorte quoi en entier...\n\
      \                    #frame_with_flush = frame + ([0.0] * 30)\n            \
      \        # je fais plus, pour pouvoir avoir plus de controle sur le timing...\n\
      \                    \n                    self.burst_queue.append(frame_with_flush)\n\
      \            except socket.timeout:\n                continue\n            except\
      \ Exception:\n                break\n        sock.close()\n\n    def stop(self):\n\
      \        self.stop_thread.set()\n        self.thread.join(timeout=0.2)\n   \
      \     return True\n\n\n    def work(self, input_items, output_items):\n    \
      \    out = output_items[0]\n        \n        # si pas de frames courrante,\
      \ regarde si y'en a une\n        if not self.current_frame:\n            if\
      \ not self.burst_queue:\n                return 0 # halllllttttttt, on envoie\
      \ RIEN si pas de frame (donc le flowgraph meurt)\n            \n           \
      \ self.current_frame = self.burst_queue.popleft()\n            \n          \
      \  # calcul index exacts pour tags\n            abs_index = self.nitems_written(0)\n\
      \            self.add_item_tag(0, abs_index, pmt.intern(\"tx_sob\"), pmt.from_bool(True))\n\
      \            self.add_item_tag(0, abs_index + 136, pmt.intern(\"tx_eob\"), pmt.from_bool(True))\n\
      \        # on envoie la sauce dans le buffer d'output (toujours pas pig\xE9\
      \ cette magie noire merci les codes d'example)\n        n_output = min(len(out),\
      \ len(self.current_frame))\n        out[:n_output] = self.current_frame[:n_output]\n\
      \        \n        self.current_frame = self.current_frame[n_output:]\n    \
      \    \n        return n_output"
    affinity: ''
    alias: ''
    comment: ''
    ip: '''127.0.0.1'''
    maxoutbuf: '0'
    minoutbuf: '0'
    port: '52010'
  states:
    _io_cache: ('Burstidi burstidou burstiditipou', 'blk', [('ip', "'127.0.0.1'"),
      ('port', '52005')], [], [('0', 'float', 1)], '', ['ip', 'port'])
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [208, 144.0]
    rotation: 0
    state: disabled
- name: epy_block_1
  id: epy_block
  parameters:
    _source_code: "import numpy as np\nfrom gnuradio import gr\nimport pmt\n\nclass\
      \ blk(gr.basic_block):\n    def __init__(self):\n        gr.basic_block.__init__(\n\
      \            self,\n            name='DMR Gated TX Controller',\n          \
      \  in_sig=[np.complex64],\n            out_sig=[np.complex64]\n        )\n \
      \       # Initial state is Silence\n        self.state = \"SILENCE\"\n\n   \
      \ def general_work(self, input_items, output_items):\n        in0 = input_items[0]\n\
      \        out = output_items[0]\n        n_input = len(in0)\n        n_output\
      \ = len(out)\n        \n        # We process as much as we can based on buffer\
      \ availability\n        n_process = min(n_input, n_output)\n        \n     \
      \   # Get tags associated with this batch of input samples\n        tags = self.get_tags_in_window(0,\
      \ 0, n_process)\n\n        for i in range(n_process):\n            # Check if\
      \ any tags start or end a burst at this specific sample\n            for tag\
      \ in tags:\n                if tag.offset == self.nitems_read(0) + i:\n    \
      \                tag_name = pmt.symbol_to_string(tag.key)\n                \
      \    if tag_name == \"tx_sob\":\n                        self.state = \"TX\"\
      \n                    elif tag_name == \"tx_eob\":\n                       \
      \ self.state = \"SILENCE\"\n\n            # State Machine Output\n         \
      \   if self.state == \"TX\":\n                # Pass the modulated DMR signal\
      \ through\n                out[i] = in0[i]\n            else:\n            \
      \    # Output absolute zero (Radio \"Off\")\n                out[i] = 0.0001\
      \ + 0.00001j\n\n        # Consume and produce the samples\n        self.consume(0,\
      \ n_process)\n        return n_process"
    affinity: ''
    alias: ''
    comment: ''
    maxoutbuf: '8192'
    minoutbuf: '0'
  states:
    _io_cache: ('DMR Gated TX Controller', 'blk', [], [('0', 'complex', 1)], [('0',
      'complex', 1)], '', [])
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [1168, 448.0]
    rotation: 0
    state: enabled
